{
  "name": "svelte-wayfind",
  "version": "0.1.0",
  "description": "Svelte Router with high performance dynamic route matching",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "svelte-check --tsconfig ./tsconfig.json"
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "svelte": "^5.0.0",
    "svelte-check": "^3.6.0",
    "vite": "^5.0.0",
    "@sveltejs/vite-plugin-svelte": "^4.0.0-next.6",
    "vite-plugin-dts": "^3.0.0",
    "vitest": "^1.0.0"
  },
  "keywords": [
    "svelte",
    "router",
    "history-api",
    "spa",
    "trie",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/catalinfl/svelte-wayfind.git"
  },
  "homepage": "https://github.com/catalinfl/svelte-wayfind#readme",
  "bugs": {
    "url": "https://github.com/catalinfl/svelte-wayfind/issues"
  }
}